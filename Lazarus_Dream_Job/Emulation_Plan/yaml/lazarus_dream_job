    attack_id: T1049
    name: "System Network Connections Discovery"
  cti_source: "AttackIQ Intelligence"
  procedure_group: procedure_discovery
  procedure_step: "6.A"
  platforms:
    windows:
      psh,pwsh:
        command: |
          $script = @'
          $output = @()
          $output += "=== IP Configuration ==="
          $output += ipconfig /all
          $output += ""
          $output += "=== Active Network Connections ==="
          $output += netstat -ano
          $output += ""
          $output += "=== ARP Table ==="
          $output += arp -a
          $output += ""
          $output += "=== DNS Cache ==="
          $output += ipconfig /displaydns
          $output | Out-File -FilePath C:\Windows\Temp\SiteShooter_results.txt -Encoding utf8
          '@
          Set-Content -Path C:\Windows\Temp\SiteShooter.ps1 -Value $script
  executors:
  - name: powershell
    command: |
      $script = @'
      $output = @()
      $output += "=== IP Configuration ==="
      $output += ipconfig /all
      $output += ""
      $output += "=== Active Network Connections ==="
      $output += netstat -ano
      $output += ""
      $output += "=== ARP Table ==="
      $output += arp -a
      $output += ""
