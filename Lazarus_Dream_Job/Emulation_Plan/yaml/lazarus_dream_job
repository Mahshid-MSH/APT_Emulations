    name: "System Binary Proxy Execution: Rundll32"
  cti_source: "AttackIQ Intelligence"
  procedure_group: procedure_execution
  procedure_step: "1.B"
  platforms:
    windows:
      cmd:
        command: |
          rundll32.exe C:\Windows\Temp\ComparePlus.dll,StartW
  executors:
  - name: command_prompt
    command: |
      rundll32.exe C:\Windows\Temp\ComparePlus.dll,StartW

# ------------------------------------------------------------
# Step 2: Defense Evasion / Process Injection
# ------------------------------------------------------------

- id: a39d48b1-5e72-4d56-9a2f-1c4b8e7c9f3a
  name: Verify Process Injection Canary
  description: >
    The malicious DLL executed in Step 1.B performed APC process injection
    into a suspended notepad.exe process. This step verifies that the injection 
    succeeded by checking for the canary file dropped by the injected code.
  tactic: defense-evasion
  technique:
    attack_id: T1055
    name: "Process Injection"
  cti_source: "AttackIQ Intelligence"
  procedure_group: procedure_defense_evasion
  procedure_step: "2.A"
  platforms:
    windows:
      psh,pwsh:
        command: |
          Start-Sleep -Seconds 3 # Give the injected process a moment to execute
          if (Test-Path "C:\Windows\Temp\injection_canary.txt") { 
              Write-Host "Success: Canary found. Process injection executed properly." 
          } else { 
              Write-Error "Failure: Canary missing. Injection failed or was blocked." 
          }
  executors:
  - name: powershell
    command: |
      Start-Sleep -Seconds 3
      if (Test-Path "C:\Windows\Temp\injection_canary.txt") { Write-Host "Success: Canary found. Process injection executed properly." } else { Write-Error "Failure: Canary missing. Injection failed or was blocked." }

